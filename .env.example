# LearnQuest Environment Variables Template
# Copy this file to .env and fill in your keys

# 🚀 Gemini API Key (Required for ARIA AI features)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# 🔗 Stitch API Key (Optional, for advanced features)
STITCH_API_KEY=your_stitch_key_here

# 💾 Supabase Configuration (Required for Auth & Database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
